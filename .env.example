# Required: Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional: Linear integration — get a key at https://linear.app/settings/account/security
LINEAR_API_KEY=your_linear_api_key_here

# Optional: Mintlify deployment integration — get your key at https://mintlify.com/settings
MINTLIFY_API_KEY=mint_your_key_here
MINTLIFY_PROJECT_ID=your-project-id
