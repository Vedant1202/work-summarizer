{
  "name": "daily-commit-summarizer",
  "version": "0.1.0",
  "description": "Generate daily stand-up summaries from git commits using Gemini AI",
  "type": "commonjs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "standup",
    "summary",
    "gemini",
    "ai",
    "cli",
    "developer-tools",
    "linear"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vedantnandoskar/daily-commit-summarizer.git"
  },
  "bin": {
    "daily-summary": "./dist/bin/daily-summary.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/bin/daily-summary.js",
    "prepare": "npm run build",
    "dev": "tsx src/bin/daily-summary.ts",
    "start": "node dist/bin/daily-summary.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@linear/sdk": "^84.0.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
