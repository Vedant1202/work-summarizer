{
  "name": "work-summarizer",
  "version": "1.3.0",
  "description": "Generate daily stand-up summaries from git commits using Gemini AI",
  "type": "commonjs",
  "license": "MIT",
  "homepage": "https://www.npmjs.com/package/work-summarizer",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "standup",
    "summary",
    "gemini",
    "ai",
    "cli",
    "developer-tools",
    "linear"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vedant1202/work-summarizer.git"
  },
  "main": "./dist/bin/work-summary.js",
  "types": "./dist/bin/work-summary.d.ts",
  "exports": {
    ".": "./dist/bin/work-summary.js"
  },
  "bin": {
    "work-summary": "dist/bin/work-summary.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "cd ui && npm install && npm run build && cd .. && tsc && chmod +x dist/bin/work-summary.js",
    "build:backend": "tsc && chmod +x dist/bin/work-summary.js",
    "build:frontend": "cd ui && npm run build",
    "prepare": "npm run build",
    "dev": "tsx src/bin/work-summary.ts",
    "start": "node dist/bin/work-summary.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "preversion": "npm test",
    "version": "npm run changelog && git add CHANGELOG.md",
    "postversion": "git push && git push --tags && npm run release:github && npm run release:docs",
    "release:github": "gh release create v$npm_package_version --generate-notes --title v$npm_package_version",
    "release:docs": "gh workflow run deploy-docs.yml",
    "release:npm": "npm publish"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@linear/sdk": "^84.0.0",
    "commander": "^12.1.0",
    "express": "^4.21.0",
    "mustache": "^4.2.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mustache": "^4.2.6",
    "@types/node": "^22.0.0",
    "conventional-changelog-cli": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
