        <span>Branch: ${escapeHtml(report.branch)}</span>
        <span>Period: last ${escapeHtml(report.timeWindow)}</span>
        <span>${report.commitCount} commit${report.commitCount !== 1 ? 's' : ''}</span>
      </div>
    </header>

    <div class="card">
      <h2>Summary</h2>
      <div class="summary-body">
        ${summaryHtml}
      </div>
    </div>

    <div class="card">
